# --- Optional LLM configuration ---
# Leave everything below empty to run fully offline.
# The JD-match / generate / AI-improve features will simply be disabled.

# Which provider to use: openai | anthropic
LLM_PROVIDER=anthropic

# OpenAI (or any OpenAI-compatible endpoint, e.g. Ollama, LM Studio, Together, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
